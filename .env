# 数据库配置
DB_HOST=postgres
DB_PORT=5432
DB_NAME=hospital_analytics
DB_USER=postgres
DB_PASSWORD=123456

# 可视化/分析库（默认与主库一致，便于单机部署）
ANALYTICS_ENABLED=true
ANALYTICS_DB_HOST=postgres
ANALYTICS_DB_PORT=5432
ANALYTICS_DB_NAME=hospital_analytics
ANALYTICS_DB_USER=postgres
ANALYTICS_DB_PASSWORD=123456

# 后端配置
SPRING_PROFILES_ACTIVE=prod
JWT_SECRET=change-me-to-a-256-bit-secret-string-in-production
JWT_EXPIRATION_MINUTES=60
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:80,http://localhost
WS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:80,http://localhost
JAVA_OPTS=-Xms256m -Xmx512m -Dfile.encoding=UTF-8 -Duser.timezone=Asia/Shanghai

# 初始管理员账户
INIT_ADMIN_ENABLED=false
INIT_ADMIN_EMAIL=admin@hospital.local
INIT_ADMIN_PASSWORD=Admin123!
INIT_ADMIN_FULL_NAME=System Admin

# 端口配置
BACKEND_PORT=9090
FRONTEND_PORT=80
PROMETHEUS_PORT=9091
GRAFANA_PORT=3000

# Coze API 配置（生产环境建议写入系统环境变量，不直接提交真实密钥）
COZE_API_KEY=
COZE_WORKFLOW_ID=
COZE_API_URL=http://localhost:8000/api/coze/chat
COZE_ENABLED=true

# Grafana 配置
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# 时区
TZ=Asia/Shanghai
